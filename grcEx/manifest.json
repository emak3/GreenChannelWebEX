{
  "manifest_version": 3,
  "name": "Green Channel Web 配信サブウィンドウ",
  "version": "1.0.1",
  "description": "グリーンチャンネルWeb（sp.gch.jp）のライブで、1ch〜5chを映像だけ見やすい別ウィンドウで開けます。",
  "permissions": ["windows"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sp.gch.jp/*"],
      "js": ["content.js"],
      "css": ["inject.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
