{
  "manifest_version": 3,
  "name": "Green Channel Web 配信サブウィンドウ",
  "version": "1.0.0",
  "description": "sp.gch.jp のライブ配信ページで、各chを映像中心のサブウィンドウで開けます。",
  "permissions": ["windows"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sp.gch.jp/*"],
      "js": ["content.js"],
      "css": ["inject.css"],
      "run_at": "document_idle"
    }
  ]
}
